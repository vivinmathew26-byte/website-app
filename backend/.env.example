# Copy this file to .env and fill in real values. Never commit .env itself.

ENVIRONMENT=development

# --- database ---
DATABASE_URL=postgresql+psycopg2://mtt_user:mtt_password@localhost:5432/mtt_db

# --- auth ---
# Generate a real one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- CORS: comma-separated list of frontend origins allowed to call this API ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- email notifications (optional — leave blank to disable) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@mothertheresatransport.com
SMTP_USE_TLS=true

# --- WhatsApp / SMS notifications via Twilio (optional — leave blank to disable) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=
